generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}


model Sessao {
  id        String   @id @default(cuid())
  nome      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  produtos  Produto[]
}

model Produto {
  id          String   @id @default(cuid())
  sessaoId    String
  sessao      Sessao   @relation(fields: [sessaoId], references: [id], onDelete: Cascade)
  nome        String
  descricao   String
  tags        String?
  preco       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}